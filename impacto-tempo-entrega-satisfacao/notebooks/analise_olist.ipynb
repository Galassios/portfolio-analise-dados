# ==========================================
# 1. OBJETIVO DO PROJETO
# ==========================================

"""
Objetivo:
Analisar se o tempo de entrega impacta
a satisfação dos clientes no e-commerce Olist.
"""

# ==========================================
# 2. IMPORTAÇÃO DAS BIBLIOTECAS
# ==========================================

import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# ==========================================
# 3. LEITURA DOS DADOS
# ==========================================

orders = pd.read_csv('../dados/olist_orders_dataset.csv')
reviews = pd.read_csv('../dados/olist_order_reviews_dataset.csv')
items = pd.read_csv('../dados/olist_order_items_dataset.csv')
products = pd.read_csv('../dados/olist_products_dataset.csv')
customers = pd.read_csv('../dados/olist_customers_dataset.csv')

# Visualizando primeiras linhas
orders.head()

# ==========================================
# 4. PREPARAÇÃO DOS DADOS
# ==========================================

orders['order_purchase_timestamp'] = pd.to_datetime(
    orders['order_purchase_timestamp']
)

orders['order_delivered_customer_date'] = pd.to_datetime(
    orders['order_delivered_customer_date']
)

orders['tempo_entrega_dias'] = (
    orders['order_delivered_customer_date']
    - orders['order_purchase_timestamp']
).dt.days

# ==========================================
# 5. JUNÇÃO DAS TABELAS
# ==========================================

df = orders.merge(
    reviews,
    on='order_id',
    how='inner'
)

df.head()

# ==========================================
# 6. ANÁLISE 1
# DISTRIBUIÇÃO DAS AVALIAÇÕES
# ==========================================

"""
Pergunta:
Os clientes costumam avaliar bem?
"""

sns.countplot(
    x='review_score',
    data=df
)

plt.show()

# Insight:
# A maioria das avaliações é positiva,
# sugerindo boa satisfação geral.

# ==========================================
# 7. ANÁLISE 2
# TEMPO MÉDIO DE ENTREGA
# ==========================================

tempo_medio = df[
    'tempo_entrega_dias'
].mean()

tempo_medio

# Insight:
# O tempo médio de entrega é de 12 dias.

# ==========================================
# 8. ANÁLISE 3
# TEMPO DE ENTREGA X SATISFAÇÃO
# ==========================================

dados_agrupados = (
    df.groupby('review_score')
    ['tempo_entrega_dias']
    .mean()
    .reset_index()
)

sns.barplot(
    x='review_score',
    y='tempo_entrega_dias',
    data=dados_agrupados
)

plt.show()

# Insight:
# Entregas mais longas tendem
# a apresentar notas menores.

# ==========================================
# 9. ANÁLISE 4
# TOP CATEGORIAS
# ==========================================

df_produtos = items.merge(
    products,
    on='product_id'
)

categorias = (
    df_produtos[
        'product_category_name'
    ]
    .value_counts()
    .head(10)
)

sns.barplot(
    x=categorias.values,
    y=categorias.index
)

plt.show()

# ==========================================
# 10. ANÁLISE 5
# RECORRÊNCIA
# ==========================================

orders_customers = orders.merge(
    customers,
    on='customer_id'
)

compras_cliente = (
    orders_customers
    .groupby('customer_unique_id')
    ['order_id']
    .count()
)

clientes_recorrentes = (
    (compras_cliente > 1)
    .mean() * 100
)

clientes_recorrentes

# ==========================================
# 11. CONCLUSÃO
# ==========================================

"""
Principais conclusões:

1. Clientes geralmente avaliam bem.
2. Entregas demoradas reduzem satisfação.
3. Existem categorias dominantes.
4. Há oportunidade de melhorar retenção.
"""
